# ============================================
# Fill Protocol Backend — Environment
# ============================================

# ── Robinhood Chain ─────────────────────────
# 0x-prefixed EVM private key for signing transactions
PROTOCOL_PRIVATE_KEY=your_0x_private_key_here
# Protocol wallet address (derived from key if omitted)
PROTOCOL_ADDRESS=0x0000000000000000000000000000000000000000
# RPC endpoint — public is rate-limited; use Alchemy/QuickNode for production
# e.g. https://robinhood-mainnet.g.alchemy.com/v2/YOUR_KEY
ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com
CHAIN_ID=4663
EXPLORER_URL=https://robinhoodchain.blockscout.com

# ── Pons launchpad (pons.family) ────────────
# Defaults are the live mainnet contracts — override only if Pons redeploys
PONS_FACTORY=0xA5aAb3F0c6EeadF30Ef1D3Eb997108E976351feB
PONS_LOCKER=0x736D76699C26D0d966744cAe304C000d471f7F35
PONS_WETH=0x0Bd7D308f8E1639FAb988df18A8011f41EAcAD73
PONS_API_URL=https://pons.family/api

# FILL protocol token on Pons (set once launched)
FILL_TOKEN_ADDRESS=

# ── Ostium (stock perps — permissionless, Arbitrum One) ──
# No API keys needed: the protocol wallet signs trades directly.
# Fund the wallet with USDC on Arbitrum to enable trading.
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_EXPLORER_URL=https://arbiscan.io
OSTIUM_MAX_LEVERAGE=50
OSTIUM_SLIPPAGE_BPS=50

# ── Uniswap (buybacks) ──────────────────────
# Uniswap V3 SwapRouter02 on Robinhood Chain (official deployment,
# verified on-chain — factory() and WETH9() match). Override only if
# Uniswap redeploys.
UNISWAP_ROUTER=0xcaf681a66d020601342297493863e78c959e5cb2

# ── Firebase ────────────────────────────────
# JSON string of service account credentials, or path to JSON file
# Omit for mock mode (in-memory store, data lost on restart)
FIREBASE_SERVICE_ACCOUNT=

# ── Server ──────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Worker Intervals (seconds) ──────────────
MIN_INTERVAL_SECONDS=1800
MAX_INTERVAL_SECONDS=7200

# ── Risk Management ────────────────────────
# All values are decimals (0.30 = 30%)
# Take profit when PnL exceeds this % of deployed capital
TAKE_PROFIT_PCT=0.30
# Reduce position by this % when taking profit
TAKE_PROFIT_REDUCE_PCT=0.25
# Auto-reduce when drawdown exceeds this %
MAX_DRAWDOWN_PCT=0.40
# Reduce by this % on drawdown trigger
DRAWDOWN_REDUCE_PCT=0.50
# Auto-close if underlying moves this % against entry
CIRCUIT_BREAKER_PCT=0.50
# Keep this % of position fund as cash buffer
RESERVE_PCT=0.20
# Minimum USDC to deploy in a single position
MIN_DEPLOY_USD=25
# Maximum USDC per position
MAX_POSITION_USD=5000
# Total USDC kept in play across all markets
MAX_TRADING_CAPITAL_USD=1500
# Liquidation proximity warning threshold (margin ratio)
LIQUIDATION_WARNING_PCT=0.15
# Default leverage for stock perps (Ostium equities max 50)
LEVERAGE=50
# Extra stock markets the engine scalps alongside pegged tokens
EXTRA_MARKETS=TSLA,NVDA
# Default market for tokens without an explicit underlying
DEFAULT_MARKET=AAPL

# ── Telegram alerts (optional — same pattern as your other bots) ──
# Every position open/close, TP/SL, fee claim, buyback, and risk alert
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── GeckoTerminal (Robinhood Chain market data — free, no key) ──
GECKOTERMINAL_API_URL=https://api.geckoterminal.com/api/v2
GECKOTERMINAL_NETWORK=robinhood

# ── Birdeye (optional — powers the "Stocks, on-chain" panel) ──
# Live price of tokenized equities (xStocks: AAPLx, TSLAx… on Solana),
# the DeFi-native twins of the tickers the engine trades. Without a key the
# /onchain-stocks endpoint returns enabled:false and the panel stays hidden.
BIRDEYE_API_KEY=
# Rarely needed — pin specific xStock mints instead of Birdeye symbol search:
# BIRDEYE_XSTOCK_MAP={"AAPL":"<solana-mint>","TSLA":"<solana-mint>"}

# ── Trading ─────────────────────────────────
# Max simultaneous stock markets with open positions
MAX_CONCURRENT_MARKETS=3

# ── Strategy mode ───────────────────────────
# Default trading mode for the engine and new tokens:
# off | conservative | balanced | degen
TRADING_MODE=degen

# Per-token daily realized-loss limit in USD (negative number, e.g. -250).
# When a token's stop-losses exceed this in a day, no new entries open.
# Leave unset to disable.
DAILY_LOSS_LIMIT_USD=
